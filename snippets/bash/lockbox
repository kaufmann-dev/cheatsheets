#!/usr/bin/env bash
set -euo pipefail

program_name=${0##*/}
config_dir=${XDG_CONFIG_HOME:-"$HOME/.config"}/lockbox
config_file=$config_dir/config

red=$'\033[31m'
green=$'\033[32m'
yellow=$'\033[33m'
reset=$'\033[0m'

can_color_stdout() {
  [[ -t 1 && -z ${NO_COLOR-} && ${TERM-} != "dumb" ]]
}

can_color_stderr() {
  [[ -t 2 && -z ${NO_COLOR-} && ${TERM-} != "dumb" ]]
}

print_success() {
  if can_color_stdout; then
    printf '%s%s%s\n' "$green" "$*" "$reset"
  else
    printf '%s\n' "$*"
  fi
}

print_warning() {
  if can_color_stdout; then
    printf '%s%s%s\n' "$yellow" "$*" "$reset"
  else
    printf '%s\n' "$*"
  fi
}

print_error() {
  if can_color_stderr; then
    printf '%s%s%s\n' "$red" "$*" "$reset" >&2
  else
    printf '%s\n' "$*" >&2
  fi
}

print_command_error() {
  local line

  while IFS= read -r line || [[ -n $line ]]; do
    line=${line#Password: }
    line=${line#Password:}
    [[ -z $line ]] && continue
    print_error "$line"
  done <<<"$1"
}

usage() {
  printf 'Usage: %s {config|mount|unmount}\n' "$program_name" >&2
}

die() {
  print_error "$program_name: $*"
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

expand_path() {
  case ${1-} in
    "~") printf '%s\n' "$HOME" ;;
    "~/"*) printf '%s/%s\n' "$HOME" "${1#~/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

read_config() {
  volume_dir=
  mount_dir=

  [[ -f $config_file ]] || die "config not found; run '$program_name config' first"

  local line key value
  while IFS= read -r line || [[ -n $line ]]; do
    [[ -z $line || ${line:0:1} == "#" ]] && continue

    key=${line%%=*}
    value=${line#*=}

    case $key in
      volume_dir) volume_dir=$value ;;
      mount_dir) mount_dir=$value ;;
    esac
  done <"$config_file"

  [[ -n $volume_dir ]] || die "config is missing volume_dir"
  [[ -n $mount_dir ]] || die "config is missing mount_dir"
}

prompt_path() {
  local label=$1
  local current=${2-}
  local value

  if [[ -n $current ]]; then
    printf '%s [%s]: ' "$label" "$current" >&2
  else
    printf '%s: ' "$label" >&2
  fi

  IFS= read -r value
  if [[ -z $value && -n $current ]]; then
    value=$current
  fi

  [[ -n $value ]] || die "$label is required"
  expand_path "$value"
}

write_config() {
  local new_volume_dir=$1
  local new_mount_dir=$2
  local temp_file

  mkdir -p "$config_dir"
  temp_file=$(mktemp "$config_dir/config.XXXXXX")
  chmod 600 "$temp_file"

  {
    printf 'volume_dir=%s\n' "$new_volume_dir"
    printf 'mount_dir=%s\n' "$new_mount_dir"
  } >"$temp_file"

  mv "$temp_file" "$config_file"
  chmod 600 "$config_file"
}

open_mount_dir() {
  print_success "Opening: $mount_dir"
  xdg-open "$mount_dir" >/dev/null 2>&1 &
}

prepare_mount_dir() {
  local parent_dir
  parent_dir=$(dirname -- "$mount_dir")

  mkdir -p "$parent_dir"

  if [[ -e $mount_dir && ! -d $mount_dir ]]; then
    die "unlocked folder path exists but is not a directory: $mount_dir"
  fi

  if [[ -d $mount_dir ]]; then
    rmdir "$mount_dir" 2>/dev/null || die "unlocked folder already exists and is not empty: $mount_dir"
  fi
}

configure() {
  if [[ -f $config_file ]]; then
    read_config
  else
    volume_dir=
    mount_dir=
  fi

  local new_volume_dir new_mount_dir
  printf 'Configure the two folders SiriKali needs:\n' >&2
  printf '  1. Encrypted data folder: where the locked/encrypted files are stored.\n' >&2
  printf '  2. Unlocked folder: where your normal files appear after mounting.\n' >&2
  printf '     This folder should be empty or not exist yet; SiriKali creates it when mounting.\n' >&2
  printf '\n' >&2

  new_volume_dir=$(prompt_path "Encrypted data folder (locked files)" "$volume_dir")
  new_mount_dir=$(prompt_path "Unlocked folder (where files appear)" "$mount_dir")

  [[ -d $new_volume_dir ]] || die "encrypted volume path is not a directory: $new_volume_dir"
  mkdir -p "$(dirname -- "$new_mount_dir")"
  if [[ -e $new_mount_dir && ! -d $new_mount_dir ]]; then
    die "unlocked folder path exists but is not a directory: $new_mount_dir"
  fi

  write_config "$new_volume_dir" "$new_mount_dir"
  print_success "Configured $config_file"
}

mount_volume() {
  require_command sirikali
  require_command mountpoint
  require_command xdg-open
  read_config

  [[ -d $volume_dir ]] || die "encrypted volume path is not a directory: $volume_dir"

  if mountpoint -q "$mount_dir"; then
    print_warning "Already mounted: $mount_dir"
    open_mount_dir
    return 0
  fi

  prepare_mount_dir

  local password output
  printf 'Password: ' >&2
  IFS= read -r -s password
  printf '\n' >&2

  if ! output=$(printf '%s\n' "$password" | sirikali -e -b stdin -d "$volume_dir" -z "$mount_dir" -k rw 2>&1); then
    unset password
    print_command_error "$output"
    die "mount failed"
  fi
  unset password output

  mountpoint -q "$mount_dir" || die "mount command finished but mount point is not mounted: $mount_dir"
  open_mount_dir
}

unmount_volume() {
  require_command sirikali
  require_command mountpoint
  read_config

  if ! mountpoint -q "$mount_dir"; then
    print_warning "Not mounted: $mount_dir"
    return 0
  fi

  local output
  if ! output=$(sirikali -u -d "$mount_dir" 2>&1); then
    print_command_error "$output"
    die "unmount failed: $mount_dir"
  fi
  unset output

  if mountpoint -q "$mount_dir"; then
    die "unmount command finished but mount point is still mounted: $mount_dir"
  fi

  print_success "Unmounted: $mount_dir"
}

case ${1-} in
  config)
    [[ $# -eq 1 ]] || {
      usage
      exit 2
    }
    configure
    ;;
  mount)
    [[ $# -eq 1 ]] || {
      usage
      exit 2
    }
    mount_volume
    ;;
  unmount)
    [[ $# -eq 1 ]] || {
      usage
      exit 2
    }
    unmount_volume
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
